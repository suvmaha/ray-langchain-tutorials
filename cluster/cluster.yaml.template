apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig

metadata:
  name: ${EKS_CLUSTER_NAME}
  region: ${AWS_REGION}
  version: "${K8S_VERSION}"
  tags:
    cluster: ${EKS_CLUSTER_NAME}

# EKS Auto Mode — AWS manages compute, networking, storage, and load balancing.
# No node groups, no Karpenter, no EBS CSI, no LBC addon installs needed.
# eksctl creates the VPC automatically — no CDK required.
autoModeConfig:
  enabled: true
  nodePools:
    - general-purpose
    - system

iam:
  withOIDC: true
